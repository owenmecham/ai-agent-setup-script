{
  "name": "murph",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "migrate": "node --experimental-strip-types scripts/migrate.ts",
    "start": "tsx packages/core/src/index.ts",
    "murph": "tsx packages/core/src/cli.ts",
    "tui": "tsx packages/tui/src/index.tsx",
    "build:release": "pnpm build && bash packages/installer/scripts/build-payload.sh && bash packages/installer/scripts/build-apps.sh"
  },
  "dependencies": {
    "pg": "^8.13.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "turbo": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
